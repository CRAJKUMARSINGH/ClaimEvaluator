# Database Configuration
DATABASE_URL=postgresql://user:password@host:5432/database
# For Neon: postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# AI Configuration (Primary - Grok/xAI)
GROK_API_KEY=your_grok_api_key_here
GROK_BASE_URL=https://api.x.ai
GROK_MODEL=grok-2-latest

# AI Configuration (Fallback - OpenAI)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# AI Configuration (Optional - Anthropic Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# AI Configuration (Optional - Google Gemini)
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp

# Server Configuration
NODE_ENV=development
PORT=5003

# Session Configuration
SESSION_SECRET=your_random_session_secret_here_change_in_production

# Optional: Storage Configuration
STORAGE_TYPE=database
# Options: database, memory (use memory for development without DB)

# Optional: File Upload Configuration
MAX_FILE_SIZE=10485760
# 10MB in bytes

# Optional: Cache Configuration
CACHE_MAX_SIZE=104857600
# 100MB in bytes
CACHE_MAX_ITEMS=200

# Optional: CORS Configuration
CORS_ORIGIN=*
# In production, set to your frontend domain
